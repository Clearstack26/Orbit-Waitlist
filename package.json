{
  "name": "orbit-waitlist",
  "private": true,
  "version": "1.0.0",
  "description": "Orbit waitlist — static web app",
  "scripts": {
    "vendor:qrcode": "esbuild node_modules/qrcode/lib/browser.js --bundle --platform=browser --format=iife --global-name=QRCode --minify --outfile=vendor/qrcode.min.js",
    "build": "npm run vendor:qrcode",
    "vercel-build": "npm run vendor:qrcode",
    "start": "serve . -l 3000",
    "dev": "serve . -l 3000"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "qrcode": "^1.5.4",
    "serve": "^14.2.4"
  }
}
